generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Campaign {
  id            Int      @id @default(autoincrement())
  name          String
  subject       String
  content       String   @default("")
  status        Int      @default(1)
  emailType     Int      @default(1)
  ccEmails      String[] @default([])
  manualEmails  String[]
  created       DateTime @default(now())
}
